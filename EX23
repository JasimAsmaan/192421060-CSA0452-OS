#include <stdio.h>

int main() {
    int m, n;

    printf("Enter number of blocks: ");
    scanf("%d",&m);

    int block[m];
    printf("Enter block sizes:\n");
    for(int i=0;i<m;i++)
        scanf("%d",&block[i]);

    printf("Enter number of processes: ");
    scanf("%d",&n);

    int process[n];
    printf("Enter process sizes:\n");
    for(int i=0;i<n;i++)
        scanf("%d",&process[i]);

    for(int i=0;i<n;i++) {
        int allocated = 0;
        for(int j=0;j<m;j++) {
            if(block[j] >= process[i]) {
                printf("Process %d -> Block %d\n", i+1, j+1);
                block[j] -= process[i];
                allocated = 1;
                break;
            }
        }

        if(!allocated)
            printf("Process %d -> Not Allocated\n", i+1);
    }

    return 0;
}
