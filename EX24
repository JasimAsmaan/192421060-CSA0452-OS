#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd;
    char data[100];

    fd = open("test.txt", O_CREAT | O_RDWR, 0644);

    if(fd < 0) {
        printf("Error opening file\n");
        return 1;
    }

    printf("Enter data to write: ");
    scanf(" %[^\n]", data);

    write(fd, data, sizeof(data));

    lseek(fd, 0, SEEK_SET);

    read(fd, data, sizeof(data));

    printf("Data in file: %s\n", data);

    close(fd);

    return 0;
}
